# ─── Google Gemini AI ───────────────────────────────────────────────────────
# Your Google AI Studio API key (https://aistudio.google.com/app/apikey)
# ⚠️  WARNING: This key is embedded in the browser bundle at build time.
#     Anyone who views the page source can read it.
#     For production apps, route Gemini calls through your own backend instead.
VITE_GOOGLE_GEMMINI_AI_KEY=your_gemini_api_key_here

# Gemini model to use for trip generation.
# Recommended stable model: gemini-2.0-flash
# Other supported values: gemini-1.5-pro, gemini-1.5-flash-latest
# NOTE: gemini-1.5-flash (without -latest) is deprecated and will return a 404.
VITE_GEMINI_MODEL=gemini-2.0-flash

# ─── Google Places API ──────────────────────────────────────────────────────
# Used for place autocomplete and photo lookups
VITE_GOOGLE_PLACE_API=your_google_places_api_key_here
VITE_GOOGLE_PLACE_API_KEY=your_google_places_api_key_here

# ─── Google OAuth ────────────────────────────────────────────────────────────
# OAuth 2.0 client ID for Google Sign-In
VITE_GOOGLE_OUTH_CLIENT_ID=your_google_oauth_client_id_here
